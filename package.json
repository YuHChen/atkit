{
  "name": "atkit",
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://yuhchen.github.io/atkit",
  "private": true,
  "dependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-bootstrap": "^0.26.6",
    "bootstrap": "^5.3.3",
    "node-sass": "^9.0.0",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.4",
    "react-router-bootstrap": "^0.26.3",
    "react-router-dom": "^7.13.0",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "gh-pages": "^6.2.0",
    "jsdom": "^29.0.1",
    "msw": "^2.7.0",
    "prettier": "^3.3.3",
    "sass": "^1.98.0",
    "vite": "^6.4.1",
    "vite-plugin-eslint": "^1.8.1",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "data": "mkdir -p src/assets/data/ && npm run data:cards && npm run data:combos",
    "data:cards": "curl https://cb-cdn.synapsegames.com/data/cards_4432720df69433df73df49236240a736.json | python -m json.tool > src/assets/data/cards.json",
    "data:combos": "curl https://cb-cdn.synapsegames.com/data/combos_c24d7fb814bee75a2f3cb1acabe81b82.json | python -m json.tool > src/assets/data/combos.json",
    "postinstall": "mkdir -p src/assets/js/ && cp -a node_modules/@highlightjs/ src/assets/js/@highlightjs/",
    "clean": "rm -rf {build,coverage,node_modules,src/assets/js}",
    "check": "npm run style && npm run test:coverage",
    "style": "npm run lint && npm run format",
    "style:fix": "npm run lint:fix && npm run format:fix",
    "lint": "eslint --color \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --color --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "format": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:fix": "vitest run --update",
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  }
}
